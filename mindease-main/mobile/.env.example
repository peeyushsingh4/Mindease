# Copy to `.env` in this folder (optional). Expo loads EXPO_PUBLIC_* at bundle time.

# Override API base if auto-detection fails (physical device / VPN / different port).
# Use your computer's LAN IP when testing on a real phone, e.g.:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.42:5001/api

EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:5001/api

# Firebase client config (used for emergency-contact OTP via Firebase Phone Auth)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# The app also auto-tries common local ports in development (`5001`, then `5000`)
# when no `.env` override is present.

# Production API (release builds); set when you deploy the backend.
# EXPO_PUBLIC_API_BASE_URL_PROD=https://api.yourdomain.com/api

# Optional: same host as the Vite web app so dashboard can open Forum / Resource in the browser.
# EXPO_PUBLIC_WEB_APP_ORIGIN=http://192.168.1.42:5173
