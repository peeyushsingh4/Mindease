NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
# For PERSISTENT storage (recommended for production and any real use):
#   1. Create a free cluster at https://cloud.mongodb.com
#   2. Get your connection string and paste it below
#   Example: MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/mindease?retryWrites=true&w=majority
#
# If this is left as the localhost value below OR left blank, the app will fall
# back to an IN-MEMORY database — ALL DATA IS LOST ON EVERY SERVER RESTART.
MONGO_URI=mongodb://127.0.0.1:27017/mental-health-app

JWT_SECRET=super_secret_jwt_key_123456789
JWT_EXPIRE=30d

# ── AI Chatbot ────────────────────────────────────────────────────────────────
# Required: your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Guardian SMS Alerts (optional but strongly recommended) ───────────────────
# Sign up at https://www.twilio.com — free trial gives ~15 USD credits
# If these are blank, crisis alerts are still saved to DB and logged to console.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
