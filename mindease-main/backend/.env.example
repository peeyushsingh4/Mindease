NODE_ENV=development
PORT=5000

# Firebase (Backend Admin SDK)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Firebase Auth REST (for sign-in / refresh token exchange)
FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# AI Chatbot (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Chat privacy/context controls
# How many past turns are sent to the model (minimize data sent).
CHAT_CONTEXT_TURNS=8

# Guardian SMS Alerts (optional)
# TextBelt free key: "textbelt" (usually limited to 1 SMS/day)
TEXTBELT_API_KEY=textbelt
# Optional override:
# TEXTBELT_API_URL=https://textbelt.com/text
