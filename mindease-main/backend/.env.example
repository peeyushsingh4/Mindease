NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/mental-health-app

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=30d

# AI Chatbot (OpenAI)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Guardian SMS Alerts (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
